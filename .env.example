# Optional absolute path to the MPV executable. When unset, Eidetic Player uses mpv from PATH.
EIDETIC_MPV_PATH=
EIDETIC_FFMPEG_PATH=
EIDETIC_ANALYZER_ENABLED=true
EIDETIC_ANALYZER_PROFILE=desktop
EIDETIC_WAVEFORM_PRELOAD_NEXT=true

# Optional backend overrides.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=4310
